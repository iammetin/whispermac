# ── Modelle (Ordner werden getrackt, Inhalt nicht) ───────────────────────────
# Spezifische Regeln müssen VOR allgemeinen stehen

# whisper-modell: Ordner tracken, Inhalt ignorieren
models/whisper-modell/*
!models/whisper-modell/.gitkeep

# llm: Ordner tracken, Inhalt ignorieren
models/llm/*
!models/llm/.gitkeep

# Alle anderen Modell-Ordner komplett ignorieren
models/whisper 8bit/
models/whisper-large*/
models/Qwen*/

# ── Python ───────────────────────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Build-Ausgaben ────────────────────────────────────────────────────────────
dist/
build/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
*.log
